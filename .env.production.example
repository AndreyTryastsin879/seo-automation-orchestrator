APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

DOMAIN=example.com

POSTGRES_DB=mega_tools
POSTGRES_USER=mega_tools
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://mega_tools:change-me@postgres:5432/mega_tools

REDIS_URL=redis://redis:6379/0

STORAGE_ROOT=/app/storage

BOT_TOKEN=replace-with-production-bot-token
BOT_PROXY=
BOT_WEBHOOK_URL=https://example.com/bot/webhook
BOT_WEBHOOK_SECRET=replace-with-random-secret
BOT_ALLOWED_PHONE_NUMBERS=79990000000,79991111111
SECRETS_ENCRYPTION_KEY=replace-with-fernet-key
